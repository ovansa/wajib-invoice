# Copy to .env.local for local dev, and set the same vars in Vercel → Project → Settings → Environment Variables.

# Neon Postgres connection string (Neon dashboard → Connection Details → pooled URL)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Secret used to sign the session JWT cookie. Generate one:  openssl rand -base64 32
JWT_SECRET="change-me"
